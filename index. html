<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<title>黄馨怡生日快乐</title>
<style>
    body {
        margin: 0;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff758c, #ffb199);
        font-family: "Microsoft YaHei", sans-serif;
        color: white;
        text-align: center;
        overflow: hidden;
    }

    .container {
        max-width: 600px;
    }

    h1 {
        font-size: 50px;
        margin-bottom: 20px;
        animation: glow 1.5s infinite alternate;
    }

    #text {
        font-size: 24px;
        line-height: 1.6;
        min-height: 150px;
        white-space: pre-line;
    }

    @keyframes glow {
        from { text-shadow: 0 0 10px #fff; }
        to { text-shadow: 0 0 20px #ff0, 0 0 30px #ff0; }
    }

    .balloon {
        position: absolute;
        bottom: -100px;
        width: 50px;
        height: 70px;
        border-radius: 50%;
        animation: float 6s infinite;
    }

    @keyframes float {
        0% { transform: translateY(0); }
        100% { transform: translateY(-120vh); }
    }
</style>
</head>
<body>

<div class="container">
    <h1>🎉 生日快乐 🎂</h1>
    <div id="text"></div>
</div>

<script>
// 打字内容
let message = `小宝，祝你生日快乐！🎁

希望你每天都能开开心心 😊
生活非常顺利，谢谢你一直陪着我嘻嘻

也希望我们可以一直在一起，
一起走很久很久 🌙✨

爱你~ `;

// 打字机效果
let i = 0;
function typeWriter() {
    if (i < message.length) {
        document.getElementById("text").innerHTML += message.charAt(i);
        i++;
        setTimeout(typeWriter, 50);
    }
}
typeWriter();

// 气球动画
for (let i = 0; i < 18; i++) {
    let balloon = document.createElement("div");
    balloon.className = "balloon";
    balloon.style.left = Math.random（) * 100 + "vw";
    balloon.style.background = `hsl(${Math.random()*360},70%,60%)`;
    balloon.style.animationDuration = (4 + Math.random()*3) + "s";
    document.body.appendChild(balloon);
}
</script>

</body>
</html>
